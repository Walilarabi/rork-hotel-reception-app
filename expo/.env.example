# Copier en .env et renseigner les valeurs du projet Supabase Flowtym Check-in.
# La clé publishable (sb_publishable_...) est conçue pour le client : sûre côté app,
# la sécurité repose sur la RLS du backend.
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
